datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model News {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  tag         String
  date        String
  author      String
  title       String
  image       String
  description String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
